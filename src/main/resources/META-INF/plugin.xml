<idea-plugin>
    <id>ai.plyxal.ijmcp</id>
    <name>IJ-MCP</name>
    <vendor url="https://plyxal.ai">plyxal.ai</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                id="ai.plyxal.ijmcp.settings"
                displayName="IJ-MCP"
                instance="ai.plyxal.ijmcp.settings.IjMcpSettingsConfigurable"/>
        <postStartupActivity implementation="ai.plyxal.ijmcp.app.IjMcpProjectStartupActivity"/>
    </extensions>
</idea-plugin>
